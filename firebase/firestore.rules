rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Compartilhamento de decks: leitura pública (o link é o segredo;
    // com senha, o conteúdo vai cifrado e nem o servidor enxerga).
    // Só o dono logado cria/atualiza/revoga.
    match /shares/{shareId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.chunkCount is int
        && request.resource.data.chunkCount <= 40;
      allow update, delete: if request.auth != null
        && resource.data.ownerUid == request.auth.uid;

      match /chunks/{chunkId} {
        allow read: if true;
        allow write: if request.auth != null
          && get(/databases/$(database)/documents/shares/$(shareId)).data.ownerUid == request.auth.uid;
      }
    }

    // Galeria da comunidade: vitrine pública; cada doc referencia um share
    // e só o dono daquele share publica/remove.
    match /gallery/{shareId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null
        && get(/databases/$(database)/documents/shares/$(shareId)).data.ownerUid == request.auth.uid;
    }

    // Sincronização: cada usuário só enxerga o próprio espaço.
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Novidades: publicadas pelo desenvolvedor (console) — só leitura.
    match /news/{id} {
      allow read: if true;
      allow write: if false;
    }
  }
}
