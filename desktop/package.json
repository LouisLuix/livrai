{
  "name": "livrai",
  "productName": "Livrai",
  "version": "1.2.1",
  "description": "LIVRAI — Estúdio: organizador visual de entregas para quem dirige criação",
  "author": "Luis Gustavo Felix (@luisluix)",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist:win": "electron-builder --win --x64",
    "dist:mac": "electron-builder --mac zip --arm64 --x64"
  },
  "license": "MIT",
  "devDependencies": {
    "@electron/packager": "^20.0.1",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.2"
  },
  "build": {
    "appId": "br.com.livrai.app",
    "productName": "Livrai",
    "directories": {
      "output": "dist-installers"
    },
    "files": [
      "main.js",
      "app/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "shortcutName": "Livrai",
      "artifactName": "Instalar-Livrai-${version}-Windows.${ext}"
    },
    "mac": {
      "target": [
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "identity": null,
      "artifactName": "Livrai-${version}-macOS-${arch}.${ext}",
      "category": "public.app-category.productivity",
      "icon": "build/icon.icns"
    }
  }
}